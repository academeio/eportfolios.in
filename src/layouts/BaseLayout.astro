---
import "../styles/fonts.css";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CloudBanner from "../components/CloudBanner.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = "Open-source ePortfolio platform for competency-based medical education in India. EPA tracking, reflective practice, and NAAC-ready documentation.",
  ogImage = "/og-default.png",
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = `${title} | Academe ePortfolios`;

// Global structured data: Organization + WebSite
const globalJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Academe Research, Inc",
    "url": "https://academe.in",
    "logo": new URL("/favicon.svg", Astro.site).href,
    "sameAs": ["https://github.com/academeio"],
    "brand": {
      "@type": "Brand",
      "name": "Academe ePortfolios",
      "url": "https://eportfolios.in",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Academe ePortfolios",
    "url": "https://eportfolios.in",
    "description": description,
    "publisher": {
      "@type": "Organization",
      "name": "Academe Research, Inc",
    },
  },
];

// Build breadcrumb from URL path
const pathSegments = Astro.url.pathname.split("/").filter(Boolean);
const breadcrumbItems = [
  { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://eportfolios.in/" },
];
if (pathSegments.length > 0) {
  const segmentName = pathSegments[0].replace(/-/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase());
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": 2,
    "name": segmentName,
    "item": canonicalURL.href,
  });
}
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems,
};

// Combine all JSON-LD: global + breadcrumb + page-specific
const allJsonLd = [
  ...globalJsonLd,
  breadcrumbJsonLd,
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Academe ePortfolios" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
    {allJsonLd.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
    <title>{fullTitle}</title>
  </head>
  <body class="bg-surface text-text font-sans antialiased">
    <Header />
    <main>
      <slot />
    </main>
    {Astro.url.pathname !== "/" && <CloudBanner variant="slim" />}
    <Footer />
  </body>
</html>
