---
import "../styles/fonts.css";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CloudBanner from "../components/CloudBanner.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = "Open-source ePortfolio platform for competency-based medical education in India. EPA tracking, reflective practice, and NAAC-ready documentation.",
  ogImage = "/og-default.png",
  ogType = "website",
  canonicalUrl,
  jsonLd,
} = Astro.props;

const canonicalURL = canonicalUrl ? new URL(canonicalUrl) : new URL(Astro.url.pathname, Astro.site);
const fullTitle = `${title} | Academe ePortfolios`;

// Global structured data: Organization + WebSite
const globalJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Academe Research, Inc",
    "url": "https://academe.in",
    "logo": new URL("/favicon.svg", Astro.site).href,
    "sameAs": ["https://github.com/academeio"],
    "brand": {
      "@type": "Brand",
      "name": "Academe ePortfolios",
      "url": "https://eportfolios.in",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Academe ePortfolios",
    "url": "https://eportfolios.in",
    "description": description,
    "publisher": {
      "@type": "Organization",
      "name": "Academe Research, Inc",
    },
  },
];

// Build full breadcrumb from URL path segments
const pathSegments = Astro.url.pathname.split("/").filter(Boolean);
const breadcrumbItems: Record<string, unknown>[] = [
  { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://eportfolios.in/" },
];
let cumulativePath = "https://eportfolios.in";
pathSegments.forEach((seg, i) => {
  cumulativePath += `/${seg}`;
  const name = seg.replace(/-/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase());
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": i + 2,
    "name": name,
    "item": `${cumulativePath}/`,
  });
});
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems,
};

// Combine all JSON-LD: global + breadcrumb + page-specific
const allJsonLd = [
  ...globalJsonLd,
  breadcrumbJsonLd,
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Academe ePortfolios Resources" href="https://eportfolios.in/resources/rss.xml" />
    <!-- Google Analytics 4 (via Partytown web worker) -->
    <script type="text/partytown" async src="https://www.googletagmanager.com/gtag/js?id=G-HSRGNFJCR4"></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HSRGNFJCR4');
    </script>
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Academe ePortfolios" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
    {allJsonLd.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
    <link rel="stylesheet" href="https://use.typekit.net/ukf7oqk.css">
    <title>{fullTitle}</title>
  </head>
  <body class="bg-surface text-text font-sans antialiased">
    <Header />
    <main>
      <slot />
    </main>
    {Astro.url.pathname !== "/" && <CloudBanner variant="slim" />}
    <Footer />
  </body>
</html>
