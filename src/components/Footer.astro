---
const currentYear = new Date().getFullYear();
---
<footer class="bg-primary-dark text-white/80">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="md:col-span-1">
        <p class="font-serif font-bold text-xl text-white">
          Academe <span class="font-sans font-normal text-sm text-accent">ePortfolios</span>
        </p>
        <p class="mt-3 text-sm leading-relaxed">
          Open-source ePortfolio platform for competency-based medical education in India.
        </p>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Learn</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/why-eportfolios" class="hover:text-white transition-colors no-underline text-white/80">Why ePortfolios</a></li>
          <li><a href="/for-medical-colleges" class="hover:text-white transition-colors no-underline text-white/80">For Medical Colleges</a></li>
          <li><a href="/case-studies" class="hover:text-white transition-colors no-underline text-white/80">Case Studies</a></li>
          <li><a href="/resources" class="hover:text-white transition-colors no-underline text-white/80">Resources</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Company</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="hover:text-white transition-colors no-underline text-white/80">About</a></li>
          <li><a href="/demo" class="hover:text-white transition-colors no-underline text-white/80">Schedule a Demo</a></li>
          <li><a href="https://academe.in" target="_blank" rel="noopener" class="hover:text-white transition-colors no-underline text-white/80">Academe Research</a></li>
          <li><a href="https://github.com/academeio/eportfolios" target="_blank" rel="noopener" class="hover:text-white transition-colors no-underline text-white/80">GitHub</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Contact</h4>
        <ul class="space-y-2 text-sm">
          <li>hello@academe.in</li>
          <li><a href="/privacy" class="hover:text-white transition-colors no-underline text-white/80">Privacy Policy</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-white/50">&copy; {currentYear} Academe Research, Inc. All rights reserved.</p>
      <p class="text-xs text-white/50">Academe ePortfolios is free and open-source software (GPL v3).</p>
    </div>
  </div>
</footer>
