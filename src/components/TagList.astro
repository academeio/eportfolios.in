---
interface Props {
  tags: string[];
}
const { tags } = Astro.props;
---
<div class="flex flex-wrap gap-2">
  {tags.map((tag) => (
    <a
      href={`/resources/tags/${tag}`}
      class="text-xs font-medium px-2.5 py-1 rounded-full bg-primary/10 text-primary no-underline hover:bg-primary/20 transition-colors"
    >
      {tag}
    </a>
  ))}
</div>
