---
interface Props {
  variant?: "full" | "slim";
}
const { variant = "slim" } = Astro.props;
---
{variant === "full" ? (
  <section class="bg-gradient-to-br from-primary via-primary-dark to-primary py-20 px-6 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 left-10 w-32 h-32 border-2 border-white rounded-full"></div>
      <div class="absolute bottom-10 right-20 w-48 h-48 border-2 border-white rounded-full"></div>
      <div class="absolute top-1/2 left-1/3 w-20 h-20 border border-white rounded-full"></div>
    </div>

    <div class="max-w-5xl mx-auto relative">
      <div class="text-center">
        <p class="text-accent font-semibold text-sm uppercase tracking-wider mb-4">Infrastructure</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-white leading-tight">
          Hosted on Academe Cloud
        </h2>
        <p class="mt-2 text-xl text-white/90 font-medium">
          Dedicated Computing for Higher Education
        </p>
        <p class="mt-6 text-white/70 leading-relaxed max-w-2xl mx-auto">
          Your institution gets its own dedicated server — not shared hosting. Complete data isolation, Indian data centres, and infrastructure managed by a team that understands academic workflows.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://academe.net.in"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center px-8 py-3.5 text-sm font-semibold rounded-lg bg-accent text-primary-dark hover:bg-accent-light transition-colors no-underline"
          >
            Get the Best Cloud for Your Institution &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>
) : (
  <section class="bg-primary-dark py-4 px-6">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6 text-center">
      <p class="text-white/90 text-sm">
        <span class="text-accent font-semibold">Academe Cloud</span> — Dedicated Computing for Higher Education
      </p>
      <a
        href="https://academe.net.in"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center px-4 py-1.5 text-xs font-semibold rounded-md bg-accent text-primary-dark hover:bg-accent-light transition-colors no-underline whitespace-nowrap"
      >
        Get the Best Cloud for Your Institution &rarr;
      </a>
    </div>
  </section>
)}
