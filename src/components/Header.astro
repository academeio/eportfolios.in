---
const navItems = [
  { label: "Why ePortfolios", href: "/why-eportfolios" },
  { label: "For Medical Colleges", href: "/for-medical-colleges" },
  { label: "Case Studies", href: "/case-studies" },
  { label: "Resources", href: "/resources" },
  { label: "About", href: "/about" },
];

const currentPath = Astro.url.pathname;
---
<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-border">
  <nav class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 text-primary font-serif font-bold text-xl no-underline">
      Academe <span class="font-sans font-normal text-sm text-accent">ePortfolios</span>
    </a>
    <div class="hidden lg:flex items-center gap-8">
      {navItems.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            "text-sm font-medium no-underline transition-colors",
            currentPath === href || currentPath.startsWith(href + "/")
              ? "text-primary"
              : "text-text-muted hover:text-primary",
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href="/demo"
        class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-primary rounded-lg hover:bg-primary-light transition-colors no-underline"
      >
        Schedule a Demo
      </a>
    </div>
    <button
      id="mobile-menu-btn"
      class="lg:hidden p-2 text-text-muted hover:text-primary"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
  <div id="mobile-menu" class="hidden lg:hidden border-t border-border bg-white">
    <div class="px-6 py-4 space-y-3">
      {navItems.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            "block text-sm font-medium no-underline",
            currentPath === href ? "text-primary" : "text-text-muted",
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href="/demo"
        class="block text-center px-4 py-2 text-sm font-medium text-white bg-primary rounded-lg no-underline mt-4"
      >
        Schedule a Demo
      </a>
    </div>
  </div>
</header>
<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const expanded = btn.getAttribute("aria-expanded") === "true";
    btn.setAttribute("aria-expanded", String(!expanded));
    menu?.classList.toggle("hidden");
  });
</script>
