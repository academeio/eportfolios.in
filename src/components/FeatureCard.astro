---
interface Props {
  need: string;
  feature: string;
  description: string;
}
const { need, feature, description } = Astro.props;
---
<div class="bg-white rounded-xl p-6 border border-border hover:border-accent/30 transition-colors">
  <p class="text-xs uppercase tracking-wider font-medium text-accent mb-2">{need}</p>
  <h3 class="text-base font-semibold text-text">{feature}</h3>
  <p class="mt-2 text-sm text-text-muted leading-relaxed">{description}</p>
</div>
