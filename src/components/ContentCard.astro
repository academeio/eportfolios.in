---
import TagList from "./TagList.astro";

interface Props {
  title: string;
  description: string;
  category: string;
  href: string;
  pubDate: Date;
  tags: string[];
}
const { title, description, category, href, pubDate, tags } = Astro.props;

const categoryLabels: Record<string, string> = {
  guides: "Guide",
  evidence: "Evidence",
  regulatory: "Regulatory",
  glossary: "Glossary",
  "case-studies": "Case Study",
};
const categoryColors: Record<string, string> = {
  guides: "bg-primary/10 text-primary",
  evidence: "bg-accent/10 text-accent",
  regulatory: "bg-green-100 text-green-800",
  glossary: "bg-purple-100 text-purple-800",
  "case-studies": "bg-blue-100 text-blue-800",
};
const dateStr = pubDate.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
---
<a href={href} class="block bg-white rounded-xl border border-border p-6 hover:border-primary/30 hover:shadow-sm transition-all no-underline group">
  <div class="flex items-center gap-3 mb-3">
    <span class:list={["text-xs font-medium px-2 py-1 rounded-full", categoryColors[category] || "bg-gray-100 text-gray-800"]}>
      {categoryLabels[category] || category}
    </span>
    <span class="text-xs text-text-light">{dateStr}</span>
  </div>
  <h3 class="text-base font-semibold text-text group-hover:text-primary transition-colors">{title}</h3>
  <p class="mt-2 text-sm text-text-muted leading-relaxed">{description}</p>
  <div class="mt-4 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-primary/10 text-primary">
        {tag}
      </span>
    ))}
  </div>
</a>
