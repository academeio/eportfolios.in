---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialProof from "../components/SocialProof.astro";
import SectionHeading from "../components/SectionHeading.astro";
import StatCard from "../components/StatCard.astro";
import CTASection from "../components/CTASection.astro";

const features = [
  { title: "EPA tracking", desc: "SmartEvidence competency matrix" },
  { title: "Reflective journals", desc: "Structured writing with mentor feedback" },
  { title: "E-logbook", desc: "NMC/NBEMS-compliant digital logbook" },
  { title: "Mobile app", desc: "Bedside assessment on any device" },
  { title: "Open source", desc: "GPL v3, affordable pricing" },
  { title: "LMS integration", desc: "LTI 1.0 + 1.3 (Canvas, Moodle)" },
  { title: "Indian hosting", desc: "Academe Cloud, full data sovereignty" },
  { title: "NAAC ready", desc: "OBE documentation and export" },
];

const audiences = [
  {
    title: "For Deans",
    points: [
      "NMC CBME compliance confidence",
      "NAAC accreditation documentation",
      "Institution-wide analytics",
      "80% less cost than proprietary platforms",
      "Full data sovereignty — hosted in India",
    ],
    href: "/for-medical-colleges#for-deans",
  },
  {
    title: "For Heads of Department",
    points: [
      "EPA entrustment tracking per resident",
      "Resident activity monitoring",
      "Mobile bedside assessment",
      "Customisable competency frameworks",
      "Reduced paperwork",
    ],
    href: "/for-medical-colleges#for-hods",
  },
  {
    title: "For MEU Heads",
    points: [
      "Evidence-based assessment framework",
      "Faculty development opportunity",
      "Curriculum alignment tools",
      "Reflective practice integration",
      "Assessment analytics",
    ],
    href: "/for-medical-colleges#for-meu",
  },
];
---

<BaseLayout title="Home">

  <!-- Hero -->
  <section class="bg-gradient-to-b from-white to-surface py-20 md:py-28 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm uppercase tracking-wider font-medium text-accent mb-4">For Indian Medical Colleges</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-primary leading-tight">
        The ePortfolio platform your CBME programme needs
      </h1>
      <p class="mt-6 text-lg md:text-xl text-text-muted leading-relaxed max-w-3xl mx-auto">
        NMC mandates competency-based education and e-logbooks. Academe ePortfolios gives your residents EPA tracking, reflective practice, and competency documentation — in one open-source platform, built for India.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/demo" class="inline-flex items-center px-8 py-3.5 text-sm font-semibold text-white bg-primary rounded-lg hover:bg-primary-light transition-colors no-underline">
          Schedule a Demo
        </a>
        <a href="/why-eportfolios" class="inline-flex items-center px-8 py-3.5 text-sm font-semibold border border-primary text-primary rounded-lg hover:bg-primary hover:text-white transition-colors no-underline">
          Read the Evidence
        </a>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <SocialProof />

  <!-- The Problem -->
  <section class="bg-white py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeading
        eyebrow="The challenge"
        title="Paper logbooks cannot deliver what CBME demands"
        subtitle="India's medical education regulators are mandating competency-based training. Most institutions lack the tools to implement it."
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card 1 -->
        <div class="bg-white rounded-xl border border-border p-8">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-primary">NMC mandates CBME and e-logbooks</h3>
          <p class="mt-3 text-sm text-text-muted leading-relaxed">
            PGMER-2023 requires e-logbooks for PG trainees. CBME Curriculum 2024 mandates competency tracking.
          </p>
        </div>
        <!-- Card 2 -->
        <div class="bg-white rounded-xl border border-border p-8">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-primary">Competency develops longitudinally</h3>
          <p class="mt-3 text-sm text-text-muted leading-relaxed">
            EPAs require multiple workplace-based assessments over months. Paper logbooks cannot aggregate or track trends.
          </p>
        </div>
        <!-- Card 3 -->
        <div class="bg-white rounded-xl border border-border p-8">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5a17.92 17.92 0 01-8.716-2.247m0 0A8.966 8.966 0 013 12c0-1.264.26-2.466.732-3.557" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-primary">No platform serves Indian medical colleges</h3>
          <p class="mt-3 text-sm text-text-muted leading-relaxed">
            Global platforms cost USD 15-50/user/year and align with ACGME, not NMC. India's 706+ medical colleges need an affordable, regulation-aware solution.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- The Solution -->
  <section class="bg-surface py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeading
        eyebrow="The solution"
        title="Academe ePortfolios"
        subtitle="An open-source ePortfolio platform purpose-built for competency-based medical education in India. EPA tracking, reflective journals, competency frameworks, mentor feedback, and NAAC-ready documentation — all in one place."
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map(({ title, desc }) => (
          <div class="bg-white rounded-xl border border-border p-6">
            <h3 class="text-base font-semibold text-primary">{title}</h3>
            <p class="mt-2 text-sm text-text-muted leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Evidence Snapshot -->
  <section class="bg-white py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeading
        eyebrow="Evidence"
        title="What the research says"
        subtitle="ePortfolios are evidence-based tools for medical education — backed by systematic reviews and Indian studies."
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <StatCard
          stat="29%"
          label="knowledge improvement over traditional methods in Indian MBBS students using e-portfolios"
          source="Geetanjali Medical College, 2024"
          sourceUrl="https://pmc.ncbi.nlm.nih.gov/articles/PMC11691100/"
        />
        <StatCard
          stat="92%"
          label="of faculty wanted e-portfolios expanded to other subjects after a successful pilot"
          source="Geetanjali Medical College, 2024"
          sourceUrl="https://pmc.ncbi.nlm.nih.gov/articles/PMC11691100/"
        />
        <StatCard
          stat="25,000+"
          label="healthcare trainees use portfolio-based assessment in the UK's NHS Foundation Programme"
          source="NHS ePortfolios"
          sourceUrl="https://www.nhseportfolios.org/Anon/AboutUs"
        />
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="bg-surface py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeading
        eyebrow="Who it's for"
        title="Built for every stakeholder in medical education"
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {audiences.map(({ title, points, href }) => (
          <div class="bg-white rounded-xl border border-border p-8">
            <h3 class="text-xl font-serif font-bold text-primary mb-4">{title}</h3>
            <ul class="space-y-2 text-sm text-text-muted">
              {points.map((point) => (
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
            <a href={href} class="inline-block mt-6 text-sm font-medium text-accent hover:text-accent-light no-underline transition-colors">
              Learn more &rarr;
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Regulatory Alignment Bar -->
  <section class="bg-primary-dark py-12 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-white text-lg leading-relaxed">
        Aligned with
        <span class="text-accent font-semibold">NMC CBME 2024</span>,
        <span class="text-accent font-semibold">PGMER-2023</span>,
        <span class="text-accent font-semibold">NBEMS e-logbook requirements</span>, and
        <span class="text-accent font-semibold">NAAC OBE documentation standards</span>.
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection
    headline="See how ePortfolios can work for your institution"
    description="A 30-minute walkthrough tailored to your departments. See EPA tracking, competency frameworks, and resident monitoring live."
    primaryLabel="Schedule a Demo"
    primaryHref="/demo"
    secondaryLabel="Download the Guide"
    secondaryHref="/resources"
  />

</BaseLayout>
