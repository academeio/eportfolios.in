---
import BaseLayout from "../layouts/BaseLayout.astro";

const designations = [
  "Dean / Principal",
  "Head of Department",
  "MEU Head",
  "Faculty",
  "IT Administrator",
  "Other",
];

const expectations = [
  { number: "1", text: "30-minute walkthrough tailored to your departments" },
  { number: "2", text: "See EPA tracking, competency frameworks, and resident monitoring live" },
  { number: "3", text: "Discuss a free pilot for one department" },
];

const submitted = Astro.url.searchParams.get("submitted") === "true";
---

<BaseLayout title="Schedule a Demo" description="Request a personalised demo of Academe ePortfolios for your medical college.">

  <section class="bg-gradient-to-b from-white to-surface py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Left: Form -->
        <div>
          <h1 class="text-3xl md:text-4xl font-serif font-bold text-primary leading-tight">
            See Academe ePortfolios in Action
          </h1>

          {submitted ? (
            <div class="mt-8 bg-green-50 border border-green-200 rounded-xl p-8">
              <h2 class="text-xl font-semibold text-green-800">Thank you for your interest.</h2>
              <p class="mt-2 text-green-700 leading-relaxed">
                We have received your demo request and will get back to you within one working day.
              </p>
            </div>
          ) : (
            <form action="https://formsubmit.co/hello@academe.in" method="POST" class="mt-8 space-y-5">
              <input type="hidden" name="_subject" value="Demo Request from eportfolios.in" />
              <input type="hidden" name="_next" value="https://eportfolios.in/demo?submitted=true" />
              <input type="hidden" name="_captcha" value="false" />

              <div>
                <label for="name" class="block text-sm font-medium text-text mb-1">Name <span class="text-red-500">*</span></label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-text text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent" />
              </div>

              <div>
                <label for="designation" class="block text-sm font-medium text-text mb-1">Designation <span class="text-red-500">*</span></label>
                <select id="designation" name="designation" required class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-text text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent">
                  <option value="">Select your role</option>
                  {designations.map((d) => <option value={d}>{d}</option>)}
                </select>
              </div>

              <div>
                <label for="institution" class="block text-sm font-medium text-text mb-1">Institution Name <span class="text-red-500">*</span></label>
                <input type="text" id="institution" name="institution" required class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-text text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent" />
              </div>

              <div>
                <label for="city" class="block text-sm font-medium text-text mb-1">City / State <span class="text-red-500">*</span></label>
                <input type="text" id="city" name="city" required class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-text text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent" />
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-text mb-1">Email <span class="text-red-500">*</span></label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-text text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent" />
              </div>

              <div>
                <label for="phone" class="block text-sm font-medium text-text mb-1">Phone</label>
                <input type="tel" id="phone" name="phone" class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-text text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent" />
              </div>

              <div>
                <label for="departments" class="block text-sm font-medium text-text mb-1">Number of PG Departments</label>
                <input type="number" id="departments" name="departments" min="1" class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-text text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent" />
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-text mb-1">Message</label>
                <textarea id="message" name="message" rows="3" class="w-full px-4 py-2.5 rounded-lg border border-border bg-white text-text text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent resize-vertical"></textarea>
              </div>

              <button type="submit" class="w-full px-6 py-3 text-sm font-semibold text-white bg-primary rounded-lg hover:bg-primary-light transition-colors cursor-pointer">
                Request a Demo
              </button>
            </form>
          )}

          <p class="mt-6 text-sm text-text-muted">
            Or email us directly at <a href="mailto:hello@academe.in" class="text-accent hover:text-accent-light no-underline font-medium">hello@academe.in</a>
          </p>
          <p class="mt-2 text-xs text-text-light">
            Your data stays with us. We don't share your information. See our <a href="/privacy" class="text-accent hover:text-accent-light no-underline">Privacy Policy</a>.
          </p>
        </div>

        <!-- Right: What to expect -->
        <div class="lg:pt-16">
          <h2 class="text-2xl font-serif font-bold text-primary mb-8">What to expect</h2>
          <div class="space-y-8">
            {expectations.map(({ number, text }) => (
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
                  <span class="text-accent font-bold text-sm">{number}</span>
                </div>
                <p class="text-text-muted leading-relaxed pt-2">{text}</p>
              </div>
            ))}
          </div>

          <div class="mt-12 bg-surface rounded-xl border border-border p-8">
            <p class="text-sm font-medium text-primary mb-2">Already trusted by</p>
            <p class="text-2xl font-bold text-primary">3,611+</p>
            <p class="text-sm text-text-muted">users at Sri Balaji Vidyapeeth University, Puducherry</p>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
