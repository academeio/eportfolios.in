---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policy" description="Privacy policy for the Academe ePortfolios website.">

  <section class="py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-serif font-bold text-primary">Privacy Policy</h1>
      <p class="mt-2 text-sm text-text-light">Last updated: 12-03-2026</p>

      <div class="mt-10 space-y-8 text-text-muted leading-relaxed">

        <div>
          <h2 class="text-lg font-semibold text-text mb-2">What we collect</h2>
          <p>
            Contact information submitted via the demo request form on this website: your name, email address, institution name, designation, city/state, and any optional details you provide (phone number, number of departments, message).
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text mb-2">How we use it</h2>
          <p>
            We use this information solely to respond to your demo request and provide information about Academe ePortfolios. We may follow up by email to schedule a demonstration or answer questions about the platform.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text mb-2">Cookies</h2>
          <p>
            This website does not use tracking cookies. No analytics are collected on this website.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text mb-2">Data sharing</h2>
          <p>
            We do not sell or share your information with third parties. Demo form submissions are processed through <a href="https://formsubmit.co" target="_blank" rel="noopener" class="text-accent hover:text-accent-light no-underline">FormSubmit</a> and delivered to us by email.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text mb-2">Data retention</h2>
          <p>
            We retain contact information for the purpose of follow-up communication regarding your demo request. You can request deletion of your data at any time by emailing us.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text mb-2">Contact</h2>
          <p>
            For privacy inquiries or data deletion requests, email <a href="mailto:hello@academe.in" class="text-accent hover:text-accent-light no-underline font-medium">hello@academe.in</a>.
          </p>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
